{
  "agents": {
    "defaults": {
      "provider": "siliconflow",
      "model": "deepseek-ai/DeepSeek-V3.2",
      "timezone": "Asia/Shanghai",
      "maxTokens": 8192,
      "contextWindowTokens": 65536,
      "temperature": 0.3,
      "maxToolIterations": 50,
      "unifiedSession": true,
      "disabledSkills": []
    }
  },

  "providers": {
    "siliconflow": {
      "apiKey": "${SILICONFLOW_API_KEY}",
      "apiBase": "https://api.siliconflow.cn/v1"
    }
  },

  "channels": {
    "sendProgress": true,
    "sendToolHints": false,
    "feishu": {
      "enabled": true,
      "appId": "${FEISHU_APP_ID}",
      "appSecret": "${FEISHU_APP_SECRET}",
      "groupPolicy": "mention",
      "streaming": true,
      "reactEmoji": "THUMBSUP",
      "domain": "feishu",
      "allowFrom": ["*"]
    }
  },

  "tools": {
    "web": {
      "enable": true,
      "search": {
        "provider": "duckduckgo"
      }
    },
    "exec": {
      "enable": true,
      "timeout": 120,
      "pathAppend": "${AIOS_PATH_APPEND}",
      "allowedEnvKeys": [
        "DATABASE_URL",
        "SILICONFLOW_API_KEY",
        "SILICONFLOW_BASE_URL",
        "LLM_MODEL_EMBEDDING",
        "ANTHROPIC_API_KEY",
        "AMAP_API_KEY",
        "AIOS_HOME",
        "AIOS_CC_WORKSPACE_ROOT",
        "AIOS_CC_TIMEOUT_S",
        "PATH",
        "VIRTUAL_ENV",
        "PYTHONPATH"
      ]
    },
    "restrictToWorkspace": false
  }
}
