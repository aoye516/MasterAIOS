# ======================
# 应用基础配置
# ======================
APP_NAME=native_ai_os
APP_ENV=development
SECRET_KEY=your-secret-key-change-in-production

# ======================
# LLM 配置 (硅基流动)
# ======================
LLM_PROVIDER=siliconflow
SILICONFLOW_API_KEY=sk-xxxx
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# 模型配置
# 注意：DeepSeek 模型需要完整路径，如 "deepseek-ai/DeepSeek-V4-Flash"
LLM_MODEL_MAIN=deepseek-ai/DeepSeek-V4-Flash
LLM_MODEL_LIGHT=Qwen/Qwen2.5-7B-Instruct
LLM_MODEL_EMBEDDING=BAAI/bge-large-zh-v1.5

# ======================
# 数据库配置（PostgreSQL + pgvector）
# ======================
# 本地开发：postgresql+asyncpg://<your_user>@localhost/aios   （trust 模式无密码）
# 生产环境：postgresql+asyncpg://aios:<password>@localhost/aios
# 切勿使用 sqlite，schema 与生产不兼容（vector(1024)、tsvector、HNSW 索引）
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aios
REDIS_URL=redis://localhost:6379/0

# ======================
# 通知渠道配置
# ======================
# 飞书
FEISHU_APP_ID=cli_xxxx
FEISHU_APP_SECRET=xxxx
FEISHU_ENABLED=true

# 邮件 (可选)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_ENABLED=false

# ======================
# 外部 API 配置
# ======================
# 天气 API (和风天气) — 旧版，可选
WEATHER_API_PROVIDER=qweather
QWEATHER_API_KEY=xxxx

# 高德地图（toolbox 子代理：路线/路况/天气/POI/geocode；wellbeing.commute_watch）
# 申请：https://lbs.amap.com/  （Web 服务 类型）
AMAP_API_KEY=

# ======================
# 系统配置
# ======================
# 时区
TIMEZONE=Asia/Shanghai

# 日志级别
LOG_LEVEL=INFO
